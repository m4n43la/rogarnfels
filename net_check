#!/bin/bash

set -euo pipefail

WEBHOOK="https://n8n.rogarnfels.cloud/webhook/net_check"
SECRET="WAZUH_MAC_WEBHOOK_2026_SECRET"
EMPRESA="Penasa"

# Detectar interfaz principal
DEV=$(ip route | awk '/default/ {print $5; exit}')

if [ -z "$DEV" ]; then
    echo "No se pudo detectar la interfaz de red."
    exit 1
fi

# Obtener MACs mediante arp-scan
MACS=$(
sudo arp-scan --interface="$DEV" --localnet 2>/dev/null \
| awk '/^[0-9]/ {print tolower($2)}' \
| grep -E '^([0-9a-f]{2}:){5}[0-9a-f]{2}$' \
| sort -u
)

if [ -z "$MACS" ]; then
    echo "No se encontraron dispositivos."
    exit 1
fi

# Crear JWT
TOKEN=$(python3 <<EOF
import jwt
print(jwt.encode({"empresa": "$EMPRESA"}, "$SECRET", algorithm="HS256"))
EOF
)

# Convertir lista de MACs a JSON
MACS_JSON=$(printf '%s\n' "$MACS" | python3 -c '
import sys,json
print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))
')

# Enviar
curl -sS -X POST "$WEBHOOK" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"empresa\":\"$EMPRESA\",\"macs\":$MACS_JSON}"
